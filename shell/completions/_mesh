#compdef mesh

_mesh() {
    local curcontext="$curcontext" state
    local -a subcommands

    subcommands=(
        'status:show cross-mesh status and per-host detail'
        'snap:generate this host snapshot'
        'update:pull and apply dotfiles ecosystem updates'
        'run:run a mesh subcommand on selected hosts'
    )

    if (( CURRENT == 2 )); then
        _arguments \
            '(-h --help)'{-h,--help}'[show help]' \
            '(-V --version)'{-V,--version}'[show version]' \
            '1:mesh subcommand:->subcommand'
        if [[ "$state" == "subcommand" ]]; then
            _describe -t commands 'mesh subcommand' subcommands
        fi
        return
    fi

    case "${words[2]}" in
        status)
            _arguments \
                '(-h --help)'{-h,--help}'[show status help]' \
                '--detail[show detail for a host alias]:host alias:' \
                '--write[refresh PROJECT_STATUS.md]' \
                '--json[emit JSON output]' \
                '--refresh[refresh cached snapshots]' \
                '*:host alias or status flag:_files'
            ;;
        snap)
            _arguments \
                '(-h --help)'{-h,--help}'[show snapshot help]' \
                '--json[emit JSON output]' \
                '--no-history[skip history update]' \
                '*:snapshot flag:_files'
            ;;
        update)
            _arguments \
                '(-h --help)'{-h,--help}'[show update help]' \
                '(-o --only)'{-o,--only}'[restrict update to one repo]:repo:(dev-bootstrap dotfiles bootstrap)' \
                '(-f --full)'{-f,--full}'[force full apply]' \
                '(-i --interactive)'{-i,--interactive}'[show dev-bootstrap full-apply menu]' \
                '--reset-auth[reset auth state during update]' \
                '--from-shell-start[mark update as shell startup triggered]' \
                '*:update flag:_files'
            ;;
        run)
            local -a run_subcommands
            run_subcommands=(
                'status:show cross-mesh status on selected hosts'
                'snap:generate snapshots on selected hosts'
                'update:pull and apply updates on selected hosts'
            )
            _arguments \
                '(-h --help)'{-h,--help}'[show run help]' \
                '--hosts[run on comma-separated host aliases]:hosts:' \
                '--online[run on online configured hosts]' \
                '--all[run on all configured hosts]' \
                '--dry-run[show commands without executing]' \
                '1:mesh subcommand:->run_subcommand' \
                '*:mesh command argument:_files'
            if [[ "$state" == "run_subcommand" ]]; then
                _describe -t commands 'mesh run subcommand' run_subcommands
            fi
            ;;
        *)
            _files
            ;;
    esac
}

_mesh "$@"
