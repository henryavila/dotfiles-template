# ~/.bashrc.local — loaded LAST by ~/.bashrc generated by dev-bootstrap.
#
# This is the "personal overrides" file. Anything you want on top of the
# dev-bootstrap defaults goes here. Safe to be opinionated — only your
# machine loads it.
#
# All the examples below are commented by default. Uncomment what you want.

# ---------- Shell options not set by the bootstrap bashrc ----------
# shopt -s globstar 2>/dev/null || true     # enable ** recursive glob

# ---------- ble.sh (fish-like autosuggestions + syntax highlighting) ----------
# Detect near the top; attach at the very bottom (ble-attach).
# [[ -f "$HOME/.local/share/blesh/ble.sh" ]] && source "$HOME/.local/share/blesh/ble.sh" --noattach

# ---------- PATH extras ----------
# Alt composer location (composer global install → ~/.config/composer/vendor/bin).
# The bootstrap 10-languages fragment already covers ~/.composer/vendor/bin.
# [ -d "$HOME/.config/composer/vendor/bin" ] && export PATH="$HOME/.config/composer/vendor/bin:$PATH"

# bun (if you install bun manually; bootstrap doesn't install it by default)
# if [ -d "$HOME/.bun" ]; then
#     export BUN_INSTALL="$HOME/.bun"
#     export PATH="$BUN_INSTALL/bin:$PATH"
# fi

# ---------- System utilities ----------
# lesspipe — nicer `less` for compressed/binary files
# [ -x /usr/bin/lesspipe ] && eval "$(SHELL=/bin/sh lesspipe)"

# dircolors — sets LS_COLORS even when eza isn't available (e.g., root shell,
# SSH session before ~/.local/bin is on PATH). Honors ~/.dircolors if present.
# if command -v dircolors >/dev/null 2>&1; then
#     if [ -r "$HOME/.dircolors" ]; then
#         eval "$(dircolors -b "$HOME/.dircolors")"
#     else
#         eval "$(dircolors -b)"
#     fi
# fi

# ---------- Bash programmable completion ----------
# Usually provided by your distro's bash-completion package. Enable if missing.
# if ! shopt -oq posix 2>/dev/null; then
#     if [ -f /usr/share/bash-completion/bash_completion ]; then
#         . /usr/share/bash-completion/bash_completion
#     elif [ -f /etc/bash_completion ]; then
#         . /etc/bash_completion
#     fi
# fi

# ---------- Editor ----------
# Simplest: a terminal editor works everywhere (local, SSH, tmux). Uncomment one:
# export EDITOR="nvim";  export VISUAL="nvim"
# export EDITOR="vim";   export VISUAL="vim"
# export EDITOR="nano";  export VISUAL="nano"
#
# Or, if you prefer a GUI editor locally and a CLI fallback over SSH:
# if [ -n "$SSH_CONNECTION" ]; then
#     export EDITOR="nano";    export VISUAL="nano"
# else
#     export EDITOR="code -w"; export VISUAL="code -w"
# fi

# ---------- FZF colors — Catppuccin Mocha (matches bootstrap starship default) ----------
# export FZF_DEFAULT_OPTS='--height 40% --layout=reverse --border --color=bg+:#313244,bg:#1e1e2e,spinner:#f5e0dc,hl:#f38ba8,fg:#cdd6f4,header:#f38ba8,info:#cba6f7,pointer:#f5e0dc,marker:#f5e0dc,fg+:#cdd6f4,prompt:#cba6f7,hl+:#f38ba8'

# ---------- ble.sh attach — MUST be the last thing in this file ----------
# if [[ ${BLE_VERSION-} ]]; then
#     ble-bind -m emacs -f 'M-RET' newline
#     ble-attach
# fi

# ---------- Personal env vars / secrets ----------
# Keep secrets OUT of this file if the repo is public. Prefer a secrets manager
# or a separate ~/.bashrc.secrets sourced from here and gitignored.
# [ -f "$HOME/.bashrc.secrets" ] && . "$HOME/.bashrc.secrets"
