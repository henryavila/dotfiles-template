# ~/.zshrc.local — loaded LAST by ~/.zshrc generated by dev-bootstrap.
# Good place for personal overrides; never committed by dev-bootstrap.

# ---------- Alias examples ----------
# alias gs='git status'
# alias gp='git pull'

# ---------- Per-machine PATH additions ----------
# export PATH="$HOME/work/scripts:$PATH"

# ---------- Editor ----------
# Simplest: a terminal editor works everywhere (local, SSH, tmux). Uncomment one:
# export EDITOR="nvim";  export VISUAL="nvim"
# export EDITOR="vim";   export VISUAL="vim"
# export EDITOR="nano";  export VISUAL="nano"

# ---------- Plugin initialization (if you use something beyond starship) ----------
# eval "$(zoxide init zsh)"
