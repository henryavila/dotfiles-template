# shell/aliases.sh â€” YOUR personal aliases, loaded into BOTH bash and zsh.
#
# Deployed by install.sh to:
#   ~/.bashrc.d/99-personal-aliases.sh    (sourced by the bashrc loader)
#   ~/.zshrc.d/99-personal-aliases.sh     (sourced by the zshrc loader)
#
# The `99-` prefix ensures these load LAST, after fragments from the
# dev-bootstrap topics (10-languages, 20-terminal-ux, 30-shell, 40-tmux,
# 50-git, 60-web-stack, 70-remote-access, â€¦). Your personal aliases WIN
# over the bootstrap defaults â€” but prefer to add value on top, not
# duplicate what's already provided.
#
# Already shipped by dev-bootstrap (do NOT re-add here unless overriding):
#
#   30-shell          â†’ .. / ... / .... / home / h / j / e / c / cla
#                       grep/fgrep/egrep --color=auto + alert (Linux)
#                       mkd / md / fs / tre helper functions
#   20-terminal-ux    â†’ ls/ll/la (eza), cat (bat), fd
#                       Phase E: topâ†’btop, dfâ†’duf, duâ†’dust, pingâ†’gping,
#                                httpâ†’xh, psâ†’procs
#   40-tmux           â†’ tl / ta / tn / tm (attach-or-create 'main')
#   50-git            â†’ g/gs/gl/gd/gco/gb/gp/gaa/gc/grb/gsh/glog/gloga
#                       whoops / gmm + __git_complete (bash)
#   60-web-stack      â†’ art / artisan / cinst / cup / fresh / migrate /
#                       refresh / rollback / seed / db:reset / aserve /
#                       dusk / phpunit / pu / puf / pud / cdump
#                       + srn / ssn / srp / ssp / srr / ssr
#   70-remote-access  â†’ ts / tip / tup / tdown / tnetcheck / tping /
#                       tssh + tip-of() helper
#
# Full inventory: https://github.com/henryavila/dev-bootstrap/blob/main/docs/ALIASES.md
#
# Rename to `aliases.sh` (strip .example) and customize below.

# =====================================================================
# Overrides â€” redefine something from the bootstrap to suit your taste
# =====================================================================

# Richer eza (the 20-terminal-ux baseline is deliberately simple):
# if command -v eza >/dev/null 2>&1; then
#     alias ls='eza --icons --group-directories-first'
#     alias ll='eza -la --icons --group-directories-first --git'
#     alias la='eza -a --icons --group-directories-first'
#     alias lt='eza --tree --icons --level=2'
# fi

# bat with auto style (20-terminal-ux uses --style=plain):
# command -v bat    >/dev/null 2>&1 && alias cat='bat --style=auto'
# command -v batcat >/dev/null 2>&1 && alias cat='batcat --style=auto'

# =====================================================================
# Personal shortcuts â€” project names, paths, tool flags you like
# =====================================================================

# tmux project session shortcuts (same attach-or-create pattern as `tm`):
# alias tmyproj='tmux new -A -s myproject'
# alias twork='tmux new -A -s work'

# Claude Code convenience (opt-in â€” uses --dangerously-skip-permissions;
# YOUR choice whether to adopt this, NOT something the public bootstrap
# ships because it bypasses approval gates for every spawned agent):
# alias cc='claude --dangerously-skip-permissions'
# alias ccc='claude --dangerously-skip-permissions --continue'
# alias ccr='claude --dangerously-skip-permissions --resume'

# Quick cd to frequently-accessed paths:
# alias proj='cd ~/code/web/myproject'

# Tool launchers with your preferred flags:
# alias lg='lazygit'
# alias ka='kubectl apply -f'

# =====================================================================
# Personal functions
# =====================================================================

# Example: quick "open this project in my editor"
# edit() {
#     local root="${1:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
#     code "$root"
# }

# =====================================================================
# Optional: mesh-guard â€” multi-machine / multi-repo Claude Code helper
# =====================================================================
# When you `cd` into a sibling repo (template, work project, etc.) and run
# `claude`, the session loads with no memory/PROJECT_STATUS context. The
# mesh-guard wrapper detects that and offers to redirect you to your main
# dotfiles repo first.
#
# Activation (opt-in):
#   1. cp shell/mesh-repos.list.example shell/mesh-repos.list
#   2. Edit shell/mesh-repos.list â€” list one repo path per line
#   3. Uncomment the source line below
#
# When mesh-repos.list is absent, the wrapper is a no-op pass-through.
#
# DOTFILES_DIR_LOCAL="${DOTFILES_DIR:-$HOME/dotfiles}"
# [[ -n "${ZSH_VERSION:-}" ]] && [[ -f "$DOTFILES_DIR_LOCAL/shell/mesh-guard.zsh" ]] && \
#     source "$DOTFILES_DIR_LOCAL/shell/mesh-guard.zsh"
