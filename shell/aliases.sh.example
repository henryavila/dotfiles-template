# shell/aliases.sh — personal aliases loaded into BOTH bash and zsh.
#
# Deployed by install.sh to:
#   ~/.bashrc.d/99-personal-aliases.sh    (sourced by the bashrc loader)
#   ~/.zshrc.d/99-personal-aliases.sh     (sourced by the zshrc loader)
#
# The `99-` prefix ensures these load LAST, after fragments from the dev-bootstrap
# topics (10-languages, 20-terminal-ux, 50-git, ...). That means your personal
# aliases WIN over the defaults — useful to override an alias from 50-git, for
# example. But you should avoid duplicating what's already provided.
#
# Already provided by dev-bootstrap (do NOT re-add here unless you want to
# override):
#   20-terminal-ux → ls/ll/la/tree (eza), cat (bat), fd
#   50-git         → g/gs/gl/gd/gco/gb/gp/gaa/gc/grb/gsh/glog/gloga/whoops/gmm
#                    + __git_complete for g/gco/gb/gp/gd (bash only)
#
# Rename to `aliases.sh` (strip .example) and customize.

# ---------- Navigation ----------
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias home='cd ~'

# ---------- Shell shortcuts ----------
alias h='history'
alias c='clear'
alias cla='clear && ls -la'

# ---------- grep colored (idempotent — most distros already set this) ----------
alias grep='grep --color=auto'
alias fgrep='fgrep --color=auto'
alias egrep='egrep --color=auto'

# ---------- eza with icons (overrides the simpler 20-terminal-ux defaults) ----------
