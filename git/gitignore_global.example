# Global gitignore — rename to `gitignore_global`. Deployed to ~/.config/git/ignore.
# Patterns here apply to every repo on this machine, without needing each repo's .gitignore.

# OS noise
.DS_Store
Thumbs.db

# Editor scratch files
*.swp
*~
.idea/
.vscode/

# Tool-local overrides that should never be committed
# Uncomment if you use Claude Code with autoMemoryDirectory (or any tool that
# writes per-project settings.local.json with secrets or user-specific paths).
# **/.claude/settings.local.json

# Build output caches (usually in each repo's .gitignore already, but harmless here)
# .cache/
# .env.local
